generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  avatar        String?
  googleId      String   @unique
  shareSlug     String?  @unique
  /// URL segment for shared insight links (e.g. /insight/:profileSlug/...); set on first share.
  profileSlug   String?  @unique
  allPublic     Boolean  @default(false)
  /// IANA zone for all insight emails; app syncs from the device (not user-picked in UI).
  deliveryTimeZone String @default("UTC")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  books         Book[]
  shelves       Shelf[]
  insights      Insight[]
  notificationSchedules UserNotificationSchedule[]
  notificationLastSends UserNotificationLastSend[]
}

/// Per–insight-style email schedule (local wall time uses `User.deliveryTimeZone`).
model UserNotificationSchedule {
  userId      String
  style       InsightStyle
  enabled     Boolean      @default(false)
  localHour   Int          @default(8)
  localMinute Int          @default(0)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, style])
  @@index([userId, enabled])
}

model UserNotificationLastSend {
  userId     String
  style      InsightStyle
  lastSentAt DateTime
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, style])
}

model Shelf {
  id        String   @id @default(cuid())
  name      String
  position  Int      @default(0)
  isPublic  Boolean  @default(false)
  shareSlug String?  @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  books     Book[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Book {
  id         String    @id @default(cuid())
  title      String
  author     String?
  shelfId    String?
  shelf      Shelf?    @relation(fields: [shelfId], references: [id], onDelete: SetNull)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Stable segment for shared insight URLs; set on first share of any page in this book.
  publicSlug String?
  insights   Insight[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, publicSlug])
  @@index([userId])
  @@index([shelfId])
}

enum InsightStyle {
  MORNING_BOOST
  APPLY_TODAY
  DO_IT_NOW
  SPREAD_THE_IDEA
  TODAYS_TAKEAWAY
}

model Insight {
  id                    String          @id @default(cuid())
  content               String
  style                 InsightStyle?
  bookId                String
  book                  Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)
  userId                String
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  position              Int             @default(0)
  /// When true, this page is viewable at the public insight URL for its book/page index.
  isShared              Boolean         @default(false)
  /// Optional stable token (for future short links); set when sharing is enabled.
  shareSlug             String?         @unique
  /// Set when this insight was sent by any automated style email (at most once per insight).
  morningDigestSentAt   DateTime?
  details               InsightDetail[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([bookId])
  @@index([userId])
  @@index([userId, style, morningDigestSentAt])
}

enum DetailType {
  EXAMPLE
  STORY
  NOTE
}

model InsightDetail {
  id        String     @id @default(cuid())
  content   String
  type      DetailType @default(NOTE)
  insightId String
  insight   Insight    @relation(fields: [insightId], references: [id], onDelete: Cascade)
  position  Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([insightId])
}
